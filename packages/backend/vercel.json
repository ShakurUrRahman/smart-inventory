{
	"version": 2,
	"installCommand": "cd packages/backend && npm install",
	"builds": [
		{
			"src": "packages/backend/src/index.ts",
			"use": "@vercel/node",
			"config": {
				"includeFiles": ["packages/backend/src/**"]
			}
		}
	],
	"routes": [
		{
			"src": "/api/(.*)",
			"dest": "packages/backend/src/index.ts"
		}
	]
}
